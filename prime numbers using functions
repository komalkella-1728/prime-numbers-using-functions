#include <stdio.h>

int main() {
    int num, i, isPrime = 1;

    // Take input from user
    printf("Enter a number: ");
    scanf("%d", &num);

    // Numbers less than or equal to 1 are not prime
    if (num <= 1) {
        isPrime = 0;
    } else {
        // Check divisibility from 2 to √num
        for (i = 2; i * i <= num; i++) {
            if (num % i == 0) {
                isPrime = 0; // Not prime
                break;
            }
        }
    }

    // Print result
    if (isPrime) {
        printf("%d is a prime number.\n", num);
    } else {
        printf("%d is not a prime number.\n", num);
    }

    return 0;
}
